{
  "name": "modular-payments-console",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "node tools/scripts/dev.mjs",
    "kill:dev-ports": "for p in 3333 4200 4201 4202 4203 4205; do pids=$(lsof -ti tcp:$p 2>/dev/null); if [ -n \"$pids\" ]; then kill $pids 2>/dev/null || true; fi; done; sleep 1",
    "reset:workspace": "pnpm nx reset && rm -rf node_modules/.cache .nx/cache .nx/workspace-data dist",
    "dev:clean": "pnpm run kill:dev-ports && pnpm run reset:workspace && pnpm dev",
    "dev:shell": "pnpm nx serve shell",
    "mock:api": "node tools/mock-api/server.mjs",
    "build": "nx run-many -t build --projects=shell,auth,billing,wallet,analytics",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "graph": "nx graph",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint",
    "ci": "nx affected -t lint,test,build"
  },
  "private": true,
  "devDependencies": {
    "@babel/core": "^7.14.5",
    "@babel/preset-react": "^7.14.5",
    "@eslint/js": "^9.8.0",
    "@nx/eslint": "22.7.5",
    "@nx/eslint-plugin": "22.7.5",
    "@nx/jest": "22.7.5",
    "@nx/js": "22.7.5",
    "@nx/module-federation": "22.7.5",
    "@nx/react": "22.7.5",
    "@nx/rspack": "22.7.5",
    "@nx/web": "22.7.5",
    "@nx/workspace": "22.7.5",
    "@rspack/cli": "1.6.8",
    "@rspack/core": "1.6.8",
    "@rspack/dev-server": "^1.1.4",
    "@rspack/plugin-react-refresh": "^1.0.0",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.3.0",
    "@types/jest": "~30.0.0",
    "@types/node": "20.19.9",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "babel-jest": "~30.3.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "jest": "~30.3.0",
    "jest-environment-jsdom": "~30.3.0",
    "jest-environment-node": "~30.3.0",
    "jest-util": "~30.3.0",
    "nx": "22.7.5",
    "prettier": "~3.6.2",
    "react-refresh": "~0.14.0",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0"
  },
  "dependencies": {
    "@module-federation/enhanced": "^2.1.0",
    "@radix-ui/react-avatar": "^1.1.11",
