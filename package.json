    "@tanstack/react-query-devtools": "^5.101.0",
    "@tinyhttp/app": "^3.0.7",
    "@tinyhttp/cors": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^10.0.3",
    "json-server": "1.0.0-beta.15",
    "lowdb": "^7.0.1",
    "lucide-react": "^1.17.0",
    "milliparsec": "^5.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.77.0",
    "react-router-dom": "6.30.3",
    "sonner": "^2.0.7",
